<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0"
            prefWidth="710.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifba.saj.ads.poo.presentation.MotoristaController">

    <top>
        <VBox spacing="10.0">

            <padding>
                <Insets bottom="10.0"
                        left="10.0"
                        right="10.0"
                        top="10.0"/>
            </padding>

            <children>
                <Label text="Cadastro de Motoristas"/>

                <GridPane hgap="10.0" vgap="10.0">

                    <columnConstraints>
                        <ColumnConstraints minWidth="120.0"
                                           prefWidth="120.0"/>

                        <ColumnConstraints hgrow="ALWAYS"
                                           minWidth="200.0"/>
                    </columnConstraints>

                    <children>
                        <Label text="Nome:"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="0"/>

                        <TextField fx:id="txNome"
                                   promptText="Digite o nome"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="0"/>

                        <Label text="CNH:"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="1"/>

                        <TextField fx:id="txCnh"
                                   promptText="Digite os 11 números da CNH"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"/>

                        <Label text="Categoria da CNH:"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="2"/>

                        <ChoiceBox fx:id="cbCategoriaCnh"
                                   prefWidth="200.0"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="2"/>
                        <Label text="Validade da CNH:"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="3"/>

                        <DatePicker fx:id="dpValidadeCnh"
                                    editable="false"
                                    promptText="Selecione a validade"
                                    GridPane.columnIndex="1"
                                    GridPane.rowIndex="3"/>
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="btnCadastrar"
                                defaultButton="true"
                                mnemonicParsing="false"
                                onAction="#cadastrarMotorista"
                                text="Cadastrar motorista"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tbMotoristas">

            <BorderPane.margin>
                <Insets bottom="10.0"
                        left="10.0"
                        right="10.0"
                        top="5.0"/>
            </BorderPane.margin>

            <columns>
                <TableColumn fx:id="clmNome"
                             minWidth="130.0"
                             text="Nome"/>

                <TableColumn fx:id="clmCnh"
                             minWidth="110.0"
                             text="CNH"/>

                <TableColumn fx:id="clmCategoria"
                             minWidth="90.0"
                             text="Categoria"/>

                <TableColumn fx:id="clmValidadeCnh"
                             minWidth="110.0"
                             text="Validade CNH"/>

                <TableColumn fx:id="clmCarroAssociado"
                             minWidth="130.0"
                             text="Carro associado"/>

                <TableColumn text="Ações">
                    <columns>
                        <TableColumn fx:id="clmEditar"
                                     minWidth="70.0"
                                     text="Editar"/>

                        <TableColumn fx:id="clmApagar"
                                     minWidth="70.0"
                                     text="Apagar"/>
                    </columns>
                </TableColumn>
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>

</BorderPane>