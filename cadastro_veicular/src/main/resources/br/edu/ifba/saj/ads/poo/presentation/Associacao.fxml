<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0"
            prefWidth="710.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifba.saj.ads.poo.presentation.AssociacaoController">

    <top>
        <VBox spacing="10.0">

            <padding>
                <Insets bottom="10.0"
                        left="10.0"
                        right="10.0"
                        top="10.0"/>
            </padding>

            <children>
                <Label text="Associação entre Motorista e Veículo"/>

                <GridPane hgap="10.0"
                          vgap="10.0">

                    <columnConstraints>
                        <ColumnConstraints minWidth="120.0"
                                           prefWidth="120.0"/>

                        <ColumnConstraints hgrow="ALWAYS"
                                           minWidth="200.0"/>
                    </columnConstraints>

                    <children>
                        <Label text="Motorista:"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="0"/>

                        <ChoiceBox fx:id="cbMotorista"
                                   prefWidth="300.0"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="0"/>

                        <Label text="Veículo:"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="1"/>

                        <ChoiceBox fx:id="cbVeiculo"
                                   prefWidth="300.0"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"/>
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="btnCriarAssociacao"
                                defaultButton="true"
                                mnemonicParsing="false"
                                onAction="#criarAssociacao"
                                text="Criar associação"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tbAssociacoes">

            <BorderPane.margin>
                <Insets bottom="10.0"
                        left="10.0"
                        right="10.0"
                        top="5.0"/>
            </BorderPane.margin>

            <columns>
                <TableColumn fx:id="clmMotorista"
                             minWidth="130.0"
                             text="Motorista"/>

                <TableColumn fx:id="clmCnh"
                             minWidth="110.0"
                             text="CNH"/>

                <TableColumn fx:id="clmPlaca"
                             minWidth="90.0"
                             text="Placa"/>

                <TableColumn fx:id="clmVeiculo"
                             minWidth="130.0"
                             text="Carro associado"/>

                <TableColumn text="Ações">
                    <columns>
                        <TableColumn fx:id="clmEditar"
                                     minWidth="70.0"
                                     text="Editar"/>

                        <TableColumn fx:id="clmApagar"
                                     minWidth="70.0"
                                     text="Apagar"/>
                    </columns>
                </TableColumn>
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>

</BorderPane>