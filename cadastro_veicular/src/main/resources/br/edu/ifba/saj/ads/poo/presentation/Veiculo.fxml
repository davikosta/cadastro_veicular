<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0"
            prefWidth="710.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifba.saj.ads.poo.presentation.VeiculoController">

    <top>
        <VBox spacing="10.0">

            <padding>
                <Insets bottom="10.0"
                        left="10.0"
                        right="10.0"
                        top="10.0"/>
            </padding>

            <children>
                <Label text="Cadastro de Veículos"/>

                <GridPane hgap="10.0" vgap="10.0">

                    <columnConstraints>
                        <ColumnConstraints minWidth="120.0"
                                           prefWidth="120.0"/>

                        <ColumnConstraints hgrow="ALWAYS"
                                           minWidth="200.0"/>
                    </columnConstraints>

                    <children>
                        <Label text="Modelo:"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="0"/>

                        <TextField fx:id="txModelo"
                                   promptText="Digite o modelo do veículo"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="0"/>

                        <Label text="Placa:"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="1"/>

                        <TextField fx:id="txPlaca"
                                   promptText="Exemplo: ABC1D23"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"/>

                        <Label text="Categoria:"
                               GridPane.columnIndex="0"
                               GridPane.rowIndex="2"/>

                        <ChoiceBox fx:id="cbCategoriaVeiculo"
                                   prefWidth="200.0"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="2"/>
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="btnCadastrar"
                                defaultButton="true"
                                mnemonicParsing="false"
                                onAction="#cadastrarVeiculo"
                                text="Cadastrar veículo"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tbVeiculos">

            <BorderPane.margin>
                <Insets bottom="10.0"
                        left="10.0"
                        right="10.0"
                        top="5.0"/>
            </BorderPane.margin>

            <columns>
                <TableColumn fx:id="clmModelo"
                             minWidth="130.0"
                             text="Modelo"/>

                <TableColumn fx:id="clmPlaca"
                             minWidth="100.0"
                             text="Placa"/>

                <TableColumn fx:id="clmCategoria"
                             minWidth="90.0"
                             text="Categoria"/>

                <TableColumn fx:id="clmMotoristaAssociado"
                             minWidth="150.0"
                             text="Motorista associado"/>

                <TableColumn text="Ações">
                    <columns>
                        <TableColumn fx:id="clmEditar"
                                     minWidth="70.0"
                                     text="Editar"/>

                        <TableColumn fx:id="clmApagar"
                                     minWidth="70.0"
                                     text="Apagar"/>
                    </columns>
                </TableColumn>
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>

</BorderPane>