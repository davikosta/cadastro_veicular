<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="panePrincipal"
            prefHeight="600.0"
            prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifba.saj.ads.poo.presentation.IndexController">

    <left>
        <VBox prefWidth="190.0"
              spacing="10.0"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets bottom="15.0"
                        left="10.0"
                        right="10.0"
                        top="15.0"/>
            </padding>

            <children>
                <Label text="Menu"/>

                <Separator/>

                <Button maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#abrirDashboard"
                        text="Dashboard"/>

                <Button maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#abrirCadastroMotorista"
                        text="Cadastro de Motoristas"/>

                <Button maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#abrirCadastroVeiculo"
                        text="Cadastro de Veículos"/>

                <Button maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#abrirAssociacoes"
                        text="Associações"/>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane BorderPane.alignment="CENTER">
            <children>
                <Label text="Dashboard"/>
            </children>
        </StackPane>
    </center>

</BorderPane>